generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  CLEANING
  DISABLED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  CANCELLED
  NO_SHOW
}

enum OrderType {
  DINE_IN
  TAKEOUT
  DELIVERY
}

enum OrderChannel {
  SALON
  DELIVERY
  PICKUP
  WHATSAPP
  PHONE
  OTHER
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_KITCHEN
  READY
  SERVED
  BILLED
  PAID
  CANCELLED
}

enum KitchenItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum KitchenTicketStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum KitchenPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ModifierType {
  SINGLE
  MULTIPLE
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum PaymentMethod {
  CASH
  CARD
  YAPE
  PLIN
  TRANSFER
}

enum CashMovementType {
  INCOME
  EXPENSE
  OPENING
  CLOSING_ADJUSTMENT
}

enum InventoryMovementType {
  PURCHASE
  SALE_CONSUMPTION
  ADJUSTMENT
  WASTE
  TRANSFER_IN
  TRANSFER_OUT
}

enum ReferenceType {
  ORDER
  PURCHASE
  MANUAL
  WASTE
  TRANSFER
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  diningAreas     DiningArea[]
  tables          Table[]
  reservations    Reservation[]
  categories      Category[]
  products        Product[]
  modifiers       Modifier[]
  orders          Order[]
  kitchenTickets  KitchenTicket[]
  cashRegisters   CashRegister[]
  cashSessions    CashSession[]
  payments        Payment[]
  cashMovements   CashMovement[]
  inventoryItems  InventoryItem[]
  inventoryMoves  InventoryMovement[]
  suppliers       Supplier[]
  purchases       Purchase[]
  businessSetting BusinessSetting?
  restaurantId    String?
  restaurant      Restaurant?         @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  users           User[]
  rolePermissions RolePermission[]
}

model Permission {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  module    String
  createdAt DateTime @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model User {
  id             String    @id @default(cuid())
  branchId       String
  roleId         String
  firstName      String
  lastName       String
  documentNumber String?
  phone          String?
  email          String?   @unique
  passwordHash   String
  avatarUrl      String?
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  waiterOrders          Order[]             @relation("OrderWaiter")
  cashierOrders         Order[]             @relation("OrderCashier")
  createdReservations   Reservation[]       @relation("ReservationCreatedBy")
  openedCashSessions    CashSession[]       @relation("CashSessionOpenedBy")
  closedCashSessions    CashSession[]       @relation("CashSessionClosedBy")
  createdPayments       Payment[]           @relation("PaymentCreatedBy")
  createdCashMovements  CashMovement[]      @relation("CashMovementCreatedBy")
  createdInventoryMoves InventoryMovement[] @relation("InventoryMovementCreatedBy")
  createdPurchases      Purchase[]          @relation("PurchaseCreatedBy")
  auditLogs             AuditLog[]

  restaurantId String?
  isSuperAdmin Boolean @default(false)

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([roleId])
}

model Customer {
  id             String    @id @default(cuid())
  fullName       String
  phone          String?
  email          String?
  documentNumber String?
  address        String?
  notes          String?
  birthDate      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  reservations Reservation[]
  orders       Order[]
  payments     Payment[]

  @@index([phone])
  @@index([documentNumber])
}

model DiningArea {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  createdAt DateTime @default(now())

  branch Branch  @relation(fields: [branchId], references: [id])
  tables Table[]

  @@index([branchId])
}

model Table {
  id           String      @id @default(cuid())
  branchId     String
  diningAreaId String?
  number       Int
  name         String?
  capacity     Int
  status       TableStatus @default(FREE)
  posX         Float?
  posY         Float?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  branch       Branch        @relation(fields: [branchId], references: [id])
  diningArea   DiningArea?   @relation(fields: [diningAreaId], references: [id])
  reservations Reservation[]
  orders       Order[]

  @@unique([branchId, number])
  @@index([branchId])
  @@index([diningAreaId])
  @@index([status])
}

model Reservation {
  id          String            @id @default(cuid())
  branchId    String
  customerId  String?
  tableId     String?
  reservedFor DateTime
  partySize   Int
  status      ReservationStatus @default(PENDING)
  notes       String?
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  branch    Branch    @relation(fields: [branchId], references: [id])
  customer  Customer? @relation(fields: [customerId], references: [id])
  table     Table?    @relation(fields: [tableId], references: [id])
  createdBy User      @relation("ReservationCreatedBy", fields: [createdById], references: [id])

  @@index([branchId])
  @@index([customerId])
  @@index([tableId])
  @@index([reservedFor])
  @@index([status])
}

model Category {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id])
  products Product[]

  @@unique([branchId, name])
  @@index([branchId])
}

model Product {
  id                     String   @id @default(cuid())
  branchId               String
  categoryId             String?
  sku                    String?
  name                   String
  description            String?
  imageUrl               String?
  price                  Decimal  @db.Decimal(10, 2)
  taxRate                Decimal  @default(0.18) @db.Decimal(5, 2)
  costReference          Decimal? @db.Decimal(10, 2)
  preparationTimeMinutes Int?
  availableForSale       Boolean  @default(true)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  branch           Branch            @relation(fields: [branchId], references: [id])
  category         Category?         @relation(fields: [categoryId], references: [id])
  orderItems       OrderItem[]
  productModifiers ProductModifier[]
  recipes          Recipe[]

  @@unique([branchId, sku])
  @@index([branchId])
  @@index([categoryId])
  @@index([name])
}

model Modifier {
  id         String       @id @default(cuid())
  branchId   String
  name       String
  type       ModifierType @default(SINGLE)
  isRequired Boolean      @default(false)
  createdAt  DateTime     @default(now())

  branch       Branch            @relation(fields: [branchId], references: [id])
  options      ModifierOption[]
  productLinks ProductModifier[]

  @@unique([branchId, name])
  @@index([branchId])
}

model ModifierOption {
  id         String  @id @default(cuid())
  modifierId String
  name       String
  extraPrice Decimal @default(0) @db.Decimal(10, 2)
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  modifier Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  @@unique([modifierId, name])
  @@index([modifierId])
}

model ProductModifier {
  id         String @id @default(cuid())
  productId  String
  modifierId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifier Modifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  @@unique([productId, modifierId])
  @@index([productId])
  @@index([modifierId])
}

model Order {
  id              String       @id @default(cuid())
  branchId        String
  customerId      String?
  tableId         String?
  waiterId        String?
  cashierId       String?
  orderNumber     String
  orderType       OrderType
  channel         OrderChannel
  status          OrderStatus  @default(DRAFT)
  guestsCount     Int?
  subtotal        Decimal      @default(0) @db.Decimal(10, 2)
  tax             Decimal      @default(0) @db.Decimal(10, 2)
  discountTotal   Decimal      @default(0) @db.Decimal(10, 2)
  serviceCharge   Decimal      @default(0) @db.Decimal(10, 2)
  total           Decimal      @default(0) @db.Decimal(10, 2)
  notes           String?
  openedAt        DateTime?
  sentToKitchenAt DateTime?
  closedAt        DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  customer       Customer?       @relation(fields: [customerId], references: [id])
  table          Table?          @relation(fields: [tableId], references: [id])
  waiter         User?           @relation("OrderWaiter", fields: [waiterId], references: [id])
  cashier        User?           @relation("OrderCashier", fields: [cashierId], references: [id])
  items          OrderItem[]
  kitchenTickets KitchenTicket[]
  payments       Payment[]

  @@unique([branchId, orderNumber])
  @@index([branchId])
  @@index([tableId])
  @@index([customerId])
  @@index([status])
  @@index([openedAt])
}

model OrderItem {
  id                  String            @id @default(cuid())
  orderId             String
  productId           String?
  productNameSnapshot String
  qty                 Decimal           @db.Decimal(10, 2)
  unitPrice           Decimal           @db.Decimal(10, 2)
  taxRate             Decimal           @default(0.18) @db.Decimal(5, 2)
  discountAmount      Decimal           @default(0) @db.Decimal(10, 2)
  subtotal            Decimal           @default(0) @db.Decimal(10, 2)
  total               Decimal           @default(0) @db.Decimal(10, 2)
  notes               String?
  kitchenStatus       KitchenItemStatus @default(PENDING)
  sentToKitchenAt     DateTime?
  readyAt             DateTime?
  servedAt            DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?            @relation(fields: [productId], references: [id])
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([productId])
  @@index([kitchenStatus])
}

model OrderItemModifier {
  id                   String  @id @default(cuid())
  orderItemId          String
  modifierNameSnapshot String
  optionNameSnapshot   String
  extraPrice           Decimal @default(0) @db.Decimal(10, 2)
  qty                  Decimal @default(1) @db.Decimal(10, 2)
  total                Decimal @default(0) @db.Decimal(10, 2)

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

model KitchenTicket {
  id          String              @id @default(cuid())
  branchId    String
  orderId     String
  station     String
  priority    KitchenPriority     @default(MEDIUM)
  status      KitchenTicketStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  startedAt   DateTime?
  readyAt     DateTime?
  deliveredAt DateTime?

  branch Branch @relation(fields: [branchId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([orderId])
  @@index([status])
}

model CashRegister {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  branch   Branch        @relation(fields: [branchId], references: [id])
  sessions CashSession[]

  @@unique([branchId, code])
  @@index([branchId])
}

model CashSession {
  id                      String            @id @default(cuid())
  branchId                String
  cashRegisterId          String
  openedById              String
  closedById              String?
  openingAmount           Decimal           @db.Decimal(10, 2)
  closingAmountDeclared   Decimal?          @db.Decimal(10, 2)
  closingAmountCalculated Decimal?          @db.Decimal(10, 2)
  differenceAmount        Decimal?          @db.Decimal(10, 2)
  status                  CashSessionStatus @default(OPEN)
  openedAt                DateTime          @default(now())
  closedAt                DateTime?
  createdAt               DateTime          @default(now())

  branch        Branch         @relation(fields: [branchId], references: [id])
  cashRegister  CashRegister   @relation(fields: [cashRegisterId], references: [id])
  openedBy      User           @relation("CashSessionOpenedBy", fields: [openedById], references: [id])
  closedBy      User?          @relation("CashSessionClosedBy", fields: [closedById], references: [id])
  payments      Payment[]
  cashMovements CashMovement[]

  @@index([branchId])
  @@index([cashRegisterId])
  @@index([status])
}

model Payment {
  id            String        @id @default(cuid())
  branchId      String
  orderId       String
  cashSessionId String?
  customerId    String?
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  referenceCode String?
  currency      String        @default("PEN")
  paidAt        DateTime      @default(now())
  createdById   String
  createdAt     DateTime      @default(now())

  branch      Branch       @relation(fields: [branchId], references: [id])
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  createdBy   User         @relation("PaymentCreatedBy", fields: [createdById], references: [id])

  @@index([branchId])
  @@index([orderId])
  @@index([cashSessionId])
  @@index([customerId])
  @@index([paidAt])
}

model CashMovement {
  id            String           @id @default(cuid())
  branchId      String
  cashSessionId String
  type          CashMovementType
  concept       String
  amount        Decimal          @db.Decimal(10, 2)
  notes         String?
  createdById   String
  createdAt     DateTime         @default(now())

  branch      Branch      @relation(fields: [branchId], references: [id])
  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("CashMovementCreatedBy", fields: [createdById], references: [id])

  @@index([branchId])
  @@index([cashSessionId])
  @@index([type])
}

model InventoryItem {
  id           String   @id @default(cuid())
  branchId     String
  sku          String?
  name         String
  unit         String
  currentStock Decimal  @default(0) @db.Decimal(12, 3)
  minStock     Decimal  @default(0) @db.Decimal(12, 3)
  costPerUnit  Decimal? @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch        Branch              @relation(fields: [branchId], references: [id])
  movements     InventoryMovement[]
  recipes       Recipe[]
  purchaseItems PurchaseItem[]

  @@unique([branchId, sku])
  @@unique([branchId, name])
  @@index([branchId])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  branchId        String
  inventoryItemId String
  type            InventoryMovementType
  qty             Decimal               @db.Decimal(12, 3)
  unitCost        Decimal?              @db.Decimal(10, 2)
  referenceType   ReferenceType
  referenceId     String?
  notes           String?
  createdById     String
  createdAt       DateTime              @default(now())

  branch        Branch        @relation(fields: [branchId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("InventoryMovementCreatedBy", fields: [createdById], references: [id])

  @@index([branchId])
  @@index([inventoryItemId])
  @@index([type])
  @@index([referenceType, referenceId])
}

model Recipe {
  id              String   @id @default(cuid())
  productId       String
  inventoryItemId String
  qtyRequired     Decimal  @db.Decimal(12, 3)
  createdAt       DateTime @default(now())

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([productId, inventoryItemId])
  @@index([productId])
  @@index([inventoryItemId])
}

model Supplier {
  id          String   @id @default(cuid())
  branchId    String
  name        String
  ruc         String?
  contactName String?
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime @default(now())

  branch    Branch     @relation(fields: [branchId], references: [id])
  purchases Purchase[]

  @@index([branchId])
  @@index([ruc])
}

model Purchase {
  id             String   @id @default(cuid())
  branchId       String
  supplierId     String
  documentType   String?
  documentNumber String?
  subtotal       Decimal  @default(0) @db.Decimal(10, 2)
  tax            Decimal  @default(0) @db.Decimal(10, 2)
  total          Decimal  @default(0) @db.Decimal(10, 2)
  purchasedAt    DateTime @default(now())
  createdById    String
  createdAt      DateTime @default(now())

  branch    Branch         @relation(fields: [branchId], references: [id])
  supplier  Supplier       @relation(fields: [supplierId], references: [id])
  createdBy User           @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  items     PurchaseItem[]

  @@index([branchId])
  @@index([supplierId])
  @@index([purchasedAt])
}

model PurchaseItem {
  id              String  @id @default(cuid())
  purchaseId      String
  inventoryItemId String
  qty             Decimal @db.Decimal(12, 3)
  unitCost        Decimal @db.Decimal(10, 2)
  subtotal        Decimal @db.Decimal(10, 2)
  total           Decimal @db.Decimal(10, 2)

  purchase      Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([purchaseId])
  @@index([inventoryItemId])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  module        String
  action        String
  entityType    String
  entityId      String
  oldValuesJson Json?
  newValuesJson Json?
  ipAddress     String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model BusinessSetting {
  id           String   @id @default(cuid())
  branchId     String   @unique
  businessName String
  ruc          String?
  address      String?
  phone        String?
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Restaurant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  subdomain String    @unique
  ruc       String?
  phone     String?
  address   String?
  logoUrl   String?
  status    String    @default("ACTIVE")
  planType  String    @default("TRIMESTRAL")
  startsAt  DateTime  @default(now())
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users         User[]
  branches      Branch[]
  subscriptions Subscription[]
}

model Subscription {
  id           String   @id @default(cuid())
  restaurantId String
  planType     String
  amount       Decimal  @db.Decimal(10, 2) // Cambiado a Decimal
  startsAt     DateTime @default(now())
  endsAt       DateTime
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}